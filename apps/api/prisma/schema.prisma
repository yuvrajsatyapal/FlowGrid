generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: FK constraints and onDelete behaviors are intentionally retained in this schema.
// The project's SCHEMA.md rule ("No REFERENCES, No CASCADE") was authored for the
// Kotlin/Micronaut/Exposed stack where FK constraints interfere with ORM transaction
// patterns. For Prisma/PostgreSQL they are idiomatic and standard.
//
// All CASCADE deletes in this schema fire only on hard deletes. Since the application
// uses soft deletes (deletedAt) for all business entities, these constraints are never
// triggered in normal operation — they are a safety net against application bugs or
// direct DB access, not a liability.
//
// Activity.cardId and Activity.boardId use SET NULL (not CASCADE) so audit records
// survive if a card or board is ever hard-purged.

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum BoardVisibility {
  WORKSPACE
  PRIVATE
  PUBLIC
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// ─── User tier ────────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String?
  avatarUrl           String?
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now()) @db.Timestamptz()
  updatedAt           DateTime @updatedAt @db.Timestamptz()

  accounts             OAuthAccount[]
  ownedOrganizations   Organization[]       @relation("OrgOwner")
  orgMemberships       OrganizationMember[]
  workspaceMemberships WorkspaceMember[]
  boardMemberships     BoardMember[]
  assignedCards        Card[]               @relation("CardAssignee")
  comments             Comment[]
  activities           Activity[]
  sentInvites          WorkspaceInvite[] @relation("SentInvites")
  watchedCards         CardWatcher[]
  createdTemplates     CardTemplate[]    @relation("CreatedTemplates")
}

model OAuthAccount {
  id                String    @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime? @db.Timestamptz()
  createdAt         DateTime  @default(now()) @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ─── Organization tier ────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  ownerId   String
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  owner      User                 @relation("OrgOwner", fields: [ownerId], references: [id])
  members    OrganizationMember[]
  workspaces Workspace[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           Role     @default(MEMBER)
  createdAt      DateTime @default(now()) @db.Timestamptz()
  updatedAt      DateTime @updatedAt @db.Timestamptz()

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// ─── Workspace tier ───────────────────────────────────────────────────────────

model Workspace {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  createdAt      DateTime  @default(now()) @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @db.Timestamptz()
  deletedAt      DateTime? @db.Timestamptz()

  organization Organization     @relation(fields: [organizationId], references: [id])
  members      WorkspaceMember[]
  boards       Board[]
  invites      WorkspaceInvite[]
  cardTemplates CardTemplate[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

// ─── Board tier ───────────────────────────────────────────────────────────────

model Board {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  description String?
  visibility  BoardVisibility @default(WORKSPACE)
  coverColor  String?
  createdAt   DateTime        @default(now()) @db.Timestamptz()
  updatedAt   DateTime        @updatedAt @db.Timestamptz()
  deletedAt   DateTime?       @db.Timestamptz()

  workspace  Workspace     @relation(fields: [workspaceId], references: [id])
  members    BoardMember[]
  lists      List[]
  labels     Label[]
  activities Activity[]

  @@index([workspaceId])
}

// BoardMember is exceptions-only: for PRIVATE boards and guest access overrides.
// Permission check: if a BoardMember row exists for user+board, that role wins over
// the user's WorkspaceMember role for that specific board.
model BoardMember {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

// ─── List ─────────────────────────────────────────────────────────────────────

model List {
  id        String    @id @default(cuid())
  boardId   String
  name      String
  position  String
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()
  deletedAt DateTime? @db.Timestamptz()

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
}

// ─── Card ─────────────────────────────────────────────────────────────────────

model Card {
  id          String    @id @default(cuid())
  listId      String
  title       String
  description String?
  position    String
  priority    Priority  @default(NONE)
  startDate   DateTime? @db.Timestamptz()
  dueDate     DateTime? @db.Timestamptz()
  assigneeId  String?
  coverColor  String?
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()
  deletedAt   DateTime? @db.Timestamptz()

  list        List         @relation(fields: [listId], references: [id], onDelete: Cascade)
  assignee    User?        @relation("CardAssignee", fields: [assigneeId], references: [id])
  labels      CardLabel[]
  comments    Comment[]
  attachments Attachment[]
  activities  Activity[]
  checklists  Checklist[]
  watchers    CardWatcher[]
  blocking    CardDependency[] @relation("Blocker")
  blockedBy   CardDependency[] @relation("Blocked")

  @@index([listId])
  @@index([assigneeId])
}

// ─── Checklists ───────────────────────────────────────────────────────────────

model Checklist {
  id        String          @id @default(cuid())
  cardId    String
  title     String
  position  String
  createdAt DateTime        @default(now()) @db.Timestamptz()
  updatedAt DateTime        @updatedAt @db.Timestamptz()

  card  Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@index([cardId])
}

model ChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  text        String
  checked     Boolean  @default(false)
  position    String
  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

// ─── Card Dependencies ────────────────────────────────────────────────────────

model CardDependency {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now()) @db.Timestamptz()

  blocker Card @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked Card @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ─── Card Watchers ────────────────────────────────────────────────────────────

model CardWatcher {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  createdAt DateTime @default(now()) @db.Timestamptz()

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([cardId])
  @@index([userId])
}

// ─── Card Templates ───────────────────────────────────────────────────────────

model CardTemplate {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  priority       Priority @default(NONE)
  checklistsData Json?
  createdById    String
  createdAt      DateTime @default(now()) @db.Timestamptz()
  updatedAt      DateTime @updatedAt @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("CreatedTemplates", fields: [createdById], references: [id])

  @@index([workspaceId])
}

// ─── Labels ───────────────────────────────────────────────────────────────────

model Label {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  color     String
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@index([boardId])
}

model CardLabel {
  id        String   @id @default(cuid())
  cardId    String
  labelId   String
  createdAt DateTime @default(now()) @db.Timestamptz()

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([cardId, labelId])
  @@index([labelId])
}

// ─── Comments ─────────────────────────────────────────────────────────────────

model Comment {
  id        String    @id @default(cuid())
  cardId    String
  userId    String
  content   String
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()
  deletedAt DateTime? @db.Timestamptz()

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([cardId])
}

// ─── Attachments ──────────────────────────────────────────────────────────────

model Attachment {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  name      String
  url       String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  source    String
  title     String
  body      String?
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz()

  // No FK relation — project rule: no REFERENCES, no ON DELETE CASCADE

  @@index([userId])
  @@index([userId, read])
  @@index([userId, source])
}

// ─── Activity (append-only audit log) ────────────────────────────────────────

model Activity {
  id        String   @id @default(cuid())
  boardId   String?
  cardId    String?
  userId    String
  action    String
  metadata  Json
  createdAt DateTime @default(now()) @db.Timestamptz()

  board Board? @relation(fields: [boardId], references: [id])
  card  Card?  @relation(fields: [cardId], references: [id])
  user  User   @relation(fields: [userId], references: [id])

  @@index([boardId])
  @@index([cardId])
  @@index([userId])
}

// ─── Workspace Invites ────────────────────────────────────────────────────────

model WorkspaceInvite {
  id          String       @id @default(cuid())
  workspaceId String
  email       String
  role        Role
  token       String       @unique
  invitedById String
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime     @db.Timestamptz()
  createdAt   DateTime     @default(now()) @db.Timestamptz()
  updatedAt   DateTime     @updatedAt @db.Timestamptz()

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("SentInvites", fields: [invitedById], references: [id])

  @@unique([workspaceId, email])
  @@index([token])
  @@index([workspaceId])
}
