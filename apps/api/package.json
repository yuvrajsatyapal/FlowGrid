    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@flowgrid/types": "workspace:*",
    "@upstash/redis": "^1.34.0",

    "@prisma/client": "^5.16.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@flowgrid/eslint-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "prisma": "^5.16.2",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5"
  }
